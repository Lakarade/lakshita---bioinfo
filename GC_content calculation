# Function for calculation of GC content
def gc_content(sequence):
    # Counting G and C nucleotides
    g = sequence.count("G")
    c = sequence.count("C")

    # Calculating G and C percentage
    return (g + c) / len(sequence) * 100


sequence =""

with open("gene.fna") as file:
    for line in file:
        if not line.startswith(">"):
           sequence +=line.strip()
gc = gc_content(sequence)
at = 100 - gc

print("Sequence length:" ,
len(sequence), "bp")
print("GC_content:", round(gc,2),
"%")
print("AT content:" , round(at,2),
"%")
  
